import json
from pathlib import Path

from s3dt.pipeline import run_pipeline


def test_pipeline_runs_on_bundled_case_study():
    repo_root = Path(__file__).resolve().parents[1]
    with open(repo_root / "artifacts/case_studies/anthropic_2025/thread_graph.json", "r", encoding="utf-8") as f:
        thread = json.load(f)

    events = run_pipeline(thread, repo_root / "artifacts/case_studies/anthropic_2025/constraints.yaml")
    assert len(events) >= 1
    assert any(event.source == "scripts" and event.target == "runtime" for event in events)
